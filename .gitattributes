# Squad: .squad/ append-only files use union merge to enable conflict-free merging.
# Decisions, histories, and logs are append-only — both sides of a merge only add content.
# Using merge=union combines all lines from both branches automatically.
.squad/decisions.md merge=union
.squad/agents/*/history.md merge=union
.squad/log/** merge=union
.squad/orchestration-log/** merge=union
*.sh text eol=lf
