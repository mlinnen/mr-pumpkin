# Squad: .ai-team/ and .ai-team-templates/ are dev-only.
# These directories should NOT be merged into preview/main.
# Setting merge=ours means: in a merge, keep preview's version (which is: these dirs don't exist).
# This prevents .ai-team/ from being added when merging from dev.
.ai-team/** merge=ours
.ai-team-templates/** merge=ours

# Preserve this branch's .gitattributes during merges from other branches
.gitattributes merge=ours
