# Squad: .ai-team/ append-only files use union merge to enable conflict-free merging.
# Decisions, histories, and logs are append-only — both sides of a merge only add content.
# Using merge=union combines all lines from both branches automatically.
.ai-team/decisions.md merge=union
.ai-team/agents/*/history.md merge=union
.ai-team/log/** merge=union
.ai-team/orchestration-log/** merge=union
